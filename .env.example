# Salin file ini menjadi ".env" lalu isi nilainya masing-masing.
# Generate SECRET_KEY baru dengan:
#   python3 -c "import secrets,string; c=string.ascii_letters+string.digits+'!@#%^&*(-_=+)'; print(''.join(secrets.choice(c) for _ in range(50)))"

DJANGO_SECRET_KEY=ganti-dengan-secret-key-acak-anda
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
