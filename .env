# Konfigurasi lokal/development BramasJaya.
# File ini TIDAK boleh di-commit ke Git / dibagikan ke publik.

# ⚠️  WAJIB diganti sebelum hosting!
# Generate SECRET_KEY baru:
#   python3 -c "import secrets,string; c=string.ascii_letters+string.digits+'!@#%^&*(-_=+)'; print(''.join(secrets.choice(c) for _ in range(50)))"
DJANGO_SECRET_KEY=GANTI-DENGAN-SECRET-KEY-BARU-YANG-AMAN

# Set ke False saat production
DJANGO_DEBUG=False

# Tambahkan domain hosting kamu (pisah koma, tanpa spasi)
# Contoh: DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,bramasjaya.com,www.bramasjaya.com
# Gunakan * jika hosting belum punya domain tetap dan ingin menghindari 400 Bad Request.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,*
